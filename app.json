{
  "expo": {
    "name": "QR-SERVE",
    "slug": "qr-serve",
    "scheme": "qrserve",
    "version": "1.0.0",
    "main": "expo-router/entry",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "QR-SERVE ha bisogno della fotocamera per scansionare i QR Code."
        }
      ]
    ]
  }
}